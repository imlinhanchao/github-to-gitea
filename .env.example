# ===== MySQL 数据库配置 =====
DB_ROOT_PASSWORD=root
DB_USER=gitea_user
DB_PASSWORD=gitea_password
DB_DATABASE=github_to_gitea
DB_PORT=3306

# ===== Gitea 配置 =====
# Gitea 管理员账号将在 Web 界面初始化时创建，此处无需配置
# Gitea HTTP 和 SSH 端口
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=222

# ===== github-to-gitea 应用端口 =====
# 应用服务端口
APP_PORT=3001

# 注意：github-to-gitea 应用的其他配置（GitHub Token、Gitea Token 等）
# 在应用启动后通过 Web 界面进行配置，不通过环境变量设置
